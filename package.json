{
  "name": "lilia-workspace",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/desktop",
    "packages/*"
  ],
  "scripts": {
    "check:package-manager": "node scripts/check-package-manager.mjs",
    "preinstall": "node scripts/check-package-manager.mjs",
    "tauri": "node scripts/check-package-manager.mjs && yarn --cwd apps/desktop tauri",
    "tauri:dev": "node scripts/check-package-manager.mjs && yarn --cwd apps/desktop tauri dev",
    "tauri:build": "node scripts/check-package-manager.mjs && yarn --cwd apps/desktop tauri build",
    "dev": "node scripts/check-package-manager.mjs && yarn --cwd apps/desktop dev",
    "docs:dev": "node scripts/check-package-manager.mjs && vitepress dev docs",
    "docs:build": "node scripts/check-package-manager.mjs && vitepress build docs",
    "docs:preview": "node scripts/check-package-manager.mjs && vitepress preview docs",
    "build": "node scripts/check-package-manager.mjs && yarn --cwd apps/desktop build",
    "test": "node scripts/check-package-manager.mjs && yarn --cwd apps/desktop test",
    "verify": "node scripts/check-package-manager.mjs && yarn verify:desktop:test && yarn verify:desktop:build && yarn verify:tauri && yarn verify:contracts",
    "verify:desktop:test": "node scripts/check-package-manager.mjs && yarn --cwd apps/desktop test",
    "verify:desktop:build": "node scripts/check-package-manager.mjs && yarn --cwd apps/desktop build",
    "verify:tauri": "node scripts/check-package-manager.mjs && cargo check --manifest-path apps/desktop/src-tauri/Cargo.toml",
    "verify:contracts": "node scripts/check-package-manager.mjs && node node_modules/typescript/bin/tsc -p packages/contracts/tsconfig.json"
  },
  "devDependencies": {
    "vitepress": "^1.6.4"
  },
  "packageManager": "yarn@4.14.1"
}
